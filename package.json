{
  "version": 2,
  "builds": [
    { "src": "public/index.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/criar-pagamento", "dest": "/api/criar-pagamento.js" },
    { "src": "/api/webhook", "dest": "/api/webhook.js" },
    { "src": "/api/palpites", "dest": "/api/palpites.js" },
    { "src": "/api/resultado", "dest": "/api/resultado.js" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}